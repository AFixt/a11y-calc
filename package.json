{
  "name": "@afixt/a11y-calc",
  "version": "0.1.0",
  "type": "module",
  "description": "An accessible calculator React component with basic and scientific modes, styled after macOS Calculator.",
  "keywords": [
    "react",
    "calculator",
    "accessibility",
    "a11y",
    "wcag",
    "scientific-calculator",
    "component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AFixt/a11y-calc.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "tsc -b && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "typecheck": "tsc -b --force",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint '**/*.css' --max-warnings=0",
    "stylelint:fix": "stylelint '**/*.css' --fix",
    "markdownlint": "markdownlint-cli2 '**/*.md' '!node_modules' '!dist' '!coverage'",
    "markdownlint:fix": "markdownlint-cli2 --fix '**/*.md' '!node_modules' '!dist' '!coverage'",
    "preview": "vite preview --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build:demo && playwright test",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "3.4.10",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.3"
  }
}
